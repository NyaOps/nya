{
    "version": "0.2.0",
    "sourceLanguages": ["rust"],
    "formatters": {
        "rust": true
    },
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "nya base build",
            "cargo": {
                "args": [
                    "build",
                    "--bin=nya",
                    "--package=nya"
                ]
            },
            "args": ["base", "build", "-c", "."],
            "cwd": "${workspaceFolder}/tests/cli"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "nya capsule new",
            "cargo": {
                "args": [
                    "build",
                    "--bin=nya",
                    "--package=nya"
                ]
            },
            "args": ["capsule", "new"],
            "cwd": "${workspaceFolder}/tests/cli"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "nya pack new",
            "cargo": {
                "args": [
                    "build",
                    "--bin=nya",
                    "--package=nya"
                ]
            },
            "args": ["pack", "new"],
            "cwd": "${workspaceFolder}/tests/cli"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "nya ship",
            "cargo": {
                "args": [
                    "build",
                    "--bin=nya",
                    "--package=nya"
                ]
            },
            "args": ["ship"],
            "cwd": "${workspaceFolder}/tests/cli"
        }
    ]
}